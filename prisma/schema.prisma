// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// 従業員テーブル
model Employee {
  id                    String   @id @default(uuid())
  employeeCode          String   @unique @map("employee_code")
  name                  String
  email                 String
  passwordHash          String   @map("password_hash")
  pinHash               String?  @map("pin_hash")
  role                  String   @default("EMPLOYEE")
  jobType               String   @default("CONSTRUCTION") @map("job_type") // 追加: 職種 (CONSTRUCTION, NAIL, EYELASH, SUPPORT)
  employmentType        String   @default("FULL_TIME") @map("employment_type")
  wageType              String   @default("FIXED") @map("wage_type")
  hourlyRate            Decimal? @map("hourly_rate")
  monthlySalary         Decimal? @map("monthly_salary")
  minimumWage           Decimal  @default(1000) @map("minimum_wage")
  deemedOvertimeEnabled Boolean  @default(false) @map("deemed_overtime_enabled")
  deemedOvertimeHours   Decimal  @default(0) @map("deemed_overtime_hours")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // リレーション
  timeEntries           TimeEntry[]
  workTimeRequests      WorkTimeRequest[]
  paidLeaveRequests     PaidLeaveRequest[]
  payrollItems          PayrollItem[]
  emailLogs             EmailLog[]
  auditLogsAsUser       AuditLog[]       @relation("AuditLogUser")
  reviewedWorkRequests  WorkTimeRequest[] @relation("WorkTimeRequestReviewer")
  reviewedLeaveRequests PaidLeaveRequest[] @relation("PaidLeaveRequestReviewer")
  modifiedTimeEntries   TimeEntry[]      @relation("TimeEntryModifier")
  confirmedPayrollRuns  PayrollRun[]     @relation("PayrollRunConfirmer")
  
  // シフトリレーション
  shiftRequests         ShiftRequest[]
  shiftEntries          ShiftEntry[]

  @@map("employees")
}

// 勤怠記録テーブル
model TimeEntry {
  id            String    @id @default(uuid())
  employeeId    String    @map("employee_id")
  date          DateTime
  clockIn       DateTime  @map("clock_in")
  clockOut      DateTime? @map("clock_out")
  note          String?   // 追加: 備考（現場名や出発地点など）
  isHolidayWork Boolean   @default(false) @map("is_holiday_work")
  isPaidLeave   Boolean   @default(false) @map("is_paid_leave")
  modifiedById  String?   @map("modified_by")
  modifiedAt    DateTime? @map("modified_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // リレーション
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  modifiedBy    Employee? @relation("TimeEntryModifier", fields: [modifiedById], references: [id])
  workTimeRequests WorkTimeRequest[]

  @@unique([employeeId, date])
  @@map("time_entries")
}

// 労働時間修正申請テーブル
model WorkTimeRequest {
  id                String   @id @default(uuid())
  employeeId        String   @map("employee_id")
  timeEntryId       String   @map("time_entry_id")
  requestedClockIn  DateTime @map("requested_clock_in")
  requestedClockOut DateTime @map("requested_clock_out")
  reason            String
  status            String   @default("PENDING")
  reviewedById      String?  @map("reviewed_by")
  reviewedAt        DateTime? @map("reviewed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // リレーション
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  timeEntry         TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  reviewedBy        Employee? @relation("WorkTimeRequestReviewer", fields: [reviewedById], references: [id])

  @@map("work_time_requests")
}

// 有給申請テーブル
model PaidLeaveRequest {
  id            String    @id @default(uuid())
  employeeId    String    @map("employee_id")
  leaveDate     DateTime  @map("leave_date")
  reason        String?
  status        String    @default("PENDING")
  reviewedById  String?   @map("reviewed_by")
  reviewedAt    DateTime? @map("reviewed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // リレーション
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy    Employee? @relation("PaidLeaveRequestReviewer", fields: [reviewedById], references: [id])

  @@map("paid_leave_requests")
}

// 営業カレンダーテーブル
model BusinessCalendar {
  id        String   @id @default(uuid())
  date      DateTime @unique
  isHoliday Boolean  @default(false) @map("is_holiday")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("business_calendars")
}

// 給与確定テーブル
model PayrollRun {
  id           String    @id @default(uuid())
  yearMonth    String    @unique @map("year_month")
  status       String    @default("DRAFT")
  confirmedById String?  @map("confirmed_by")
  confirmedAt  DateTime? @map("confirmed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // リレーション
  confirmedBy  Employee?     @relation("PayrollRunConfirmer", fields: [confirmedById], references: [id])
  payrollItems PayrollItem[]

  @@map("payroll_runs")
}

// 給与明細テーブル
model PayrollItem {
  id                  String   @id @default(uuid())
  payrollRunId        String   @map("payroll_run_id")
  employeeId          String   @map("employee_id")
  baseSalary          Decimal  @map("base_salary")
  overtimePay         Decimal  @default(0) @map("overtime_pay")
  holidayPay          Decimal  @default(0) @map("holiday_pay")
  deemedOvertimePay   Decimal  @default(0) @map("deemed_overtime_pay")
  grossSalary         Decimal  @map("gross_salary")
  socialInsurance     Decimal  @default(0) @map("social_insurance")
  employmentInsurance Decimal  @default(0) @map("employment_insurance")
  incomeTax           Decimal  @default(0) @map("income_tax")
  totalDeductions     Decimal  @default(0) @map("total_deductions")
  netSalary           Decimal  @map("net_salary")
  workHours           Decimal  @default(0) @map("work_hours")
  overtimeHours       Decimal  @default(0) @map("overtime_hours")
  holidayHours        Decimal  @default(0) @map("holiday_hours")
  pdfPath             String?  @map("pdf_path")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // リレーション
  payrollRun          PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee            Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  emailLogs           EmailLog[]

  @@unique([payrollRunId, employeeId])
  @@map("payroll_items")
}

// メール送信履歴テーブル
model EmailLog {
  id            String    @id @default(uuid())
  payrollItemId String    @map("payroll_item_id")
  employeeId    String    @map("employee_id")
  sentAt        DateTime? @map("sent_at")
  status        String    @default("PENDING")
  errorMessage  String?   @map("error_message")
  retryCount    Int       @default(0) @map("retry_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // リレーション
  payrollItem   PayrollItem @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("email_logs")
}

// 監査ログテーブル
model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  // リレーション
  user       Employee @relation("AuditLogUser", fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// シフト希望（月単位）テーブル
model ShiftRequest {
  id            String       @id @default(uuid())
  employeeId    String       @map("employee_id")
  yearMonth     String       @map("year_month") // YYYY-MM
  status        String       @default("PENDING") // PENDING, APPROVED, REJECTED
  submittedAt   DateTime     @default(now()) @map("submitted_at")
  reviewedById  String?      @map("reviewed_by")
  reviewedAt    DateTime?    @map("reviewed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // リレーション
  employee      Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftEntries  ShiftEntry[] // この希望申請に含まれる日毎のシフト詳細
  
  // レビュアー向けリレーションは今回はシンプルにするためIDのみ保持か、あるいは明示的にリレーションを張るか
  // reviewedBy    Employee?    @relation("ShiftRequestReviewer", fields: [reviewedById], references: [id])

  @@unique([employeeId, yearMonth]) // 同月一回の申請とする
  @@map("shift_requests")
}

// 日別シフトテーブル（希望および確定）
model ShiftEntry {
  id             String        @id @default(uuid())
  shiftRequestId String?       @map("shift_request_id") // 申請に紐づく場合
  employeeId     String        @map("employee_id")
  date           DateTime      // 対象日
  startTime      DateTime?     @map("start_time") // シフト開始予定時間 (nullの場合は休み希望など)
  endTime        DateTime?     @map("end_time")   // シフト終了予定時間
  isRest         Boolean       @default(false) @map("is_rest") // 休み希望/休み確定フラグ
  isConfirmed    Boolean       @default(false) @map("is_confirmed") // 管理者が確定させたか
  note           String?       // 備考（希望理由や管理者からのコメント）
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // リレーション
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftRequest   ShiftRequest? @relation(fields: [shiftRequestId], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@map("shift_entries")
}
